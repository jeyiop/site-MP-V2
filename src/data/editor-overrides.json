  "textOverrides": {
    "hero-title-6": "L’excellence en point de vente pharmacie",
    "hero-title-0": "MULTIPÔLES",
    "hero-subtitle-0": "Multipôles est un G.I.E — Groupement d'Intérêt Économique — composé de plusieurs pôles spécialisés dans la création et la fabrication de supports de communication, d'emballage et de PLV. Implantés depuis 1995, nous mettons notre expertise au service des industries pharmaceutique et cosmétique.",
    "hero-details-0": "Notre gamme couvre l'intégralité des besoins en communication point de vente et conditionnement :",
    "hero-point-0-1": "PLV, ILV & présentoirs sur mesure",
    "hero-point-0-2": "Packaging pharmaceutique & cosmétique",
    "hero-metric-0": "EXPERTISE MÉTIER DEPUIS 1995",
    "hero-point-0-0": "Étuis pharmaceutiques & boîtes carton",
    "hero-title-1": "Packaging éco-responsable & premium",
    "hero-subtitle-1": "Specialists du conditionnement cosmétique haut de gamme, nous concevons des packagings qui allient naturalité, éco-responsabilité et identité de marque forte.",
    "hero-details-1": "Cartons certifiés PEFC/FSC, encres végétales, finitions nobles : notre expertise au service des marques cosmétiques exigeantes.",
    "hero-point-1-0": "Étuis & boîtes cosmétiques sur mesure",
    "hero-point-1-1": "Cartons & papiers certifiés PEFC / FSC",
    "hero-point-1-2": "Finitions premium : pelliculage, gaufrage, dorure",
    "hero-metric-1": "NATURALITÉ • ÉLÉGANCE • RESPONSABILITÉ",
    "hero-title-2": "Packaging pharmaceutique & médical",
    "hero-subtitle-2": "Experts en étuis et conditionnements pharmaceutiques, nous garantissons conformité réglementaire et qualité d'impression sur chaque référence.",
    "hero-details-2": "Du blistervac aux tuâbes et étuis carton, nous maîtrisons toute la chaîne du conditionnement pharma — conception, BAT, impression et façonnage.",
    "hero-point-2-0": "Étuis carton & boites pharma sur mesure",
    "hero-point-2-1": "Impression offset & numérique haute définition",
    "hero-point-2-2": "Conformité réglementaire & mentions légales",
    "hero-metric-2": "RIGUEUR • CONFORMITÉ • PRÉCISION",
    "hero-subtitle-3": "Visualisez votre projet en gabarit 3D avant impression : étuis, boîtes, PLV — modélisés en kraft pour valider volumes et structures.",
    "hero-details-3": "En quelques clics, configurez votre structure, renseignez vos dimensions et recevez un devis précis adapté à votre production.",
    "hero-title-4": "PLV de comptoir cosmétique & pharmacie",
    "hero-subtitle-4": "Présentoirs de comptoir personnalisés pour la cosmétique et la pharmacie : valorisez vos produits avec des PLV carton élégantes et fonctionnelles.",
    "hero-details-4": "Conception structurelle, impression et façonnage inclus : un partenaire unique pour vos PLV, de la création au point de vente.",
    "hero-point-4-0": "Présentoirs de comptoir personnalisés",
    "hero-point-4-1": "Displays pharmacie & parapharmacie",
    "hero-point-4-2": "Assemblage & conditionnement inclus",
    "hero-metric-4": "VISIBILITÉ • SÉDUCTION • PERFORMANCE",
    "hero-title-5": "Notre catalogue de structures carton",
    "hero-subtitle-5": "Du simple étui fond automatique à la PLV de sol gran format : découvrez notre gamme complète de structures carton kraft.",
    "hero-details-5": "30 ans de savoir-faire cartonnier : nos gabarits standards sont disponibles en catalogue ou adaptables à vos contraintes métier.",
    "hero-point-5-0": "Étuis, fourreaux & coffrets carton",
    "hero-point-5-1": "PLV de sol & présentoirs à gradin",
    "hero-point-5-2": "Structures sur mesure & gabarits exclusifs",
    "hero-metric-5": "ÉTUIS • PLV • FOURREAUX • COFFRETS",
    "hero-subtitle-6": "Packaging, PLV et mobilier de rayon : MULTIPÔLES accompagne les pharmacies et parapharmacies dans la mise en valeur premium de leurs produits."
  },
